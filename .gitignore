# Downloads (files are large, but keep folder structure)
downloads/*
!downloads/.gitkeep

# Logs
logs/
data/logs/

# Config runtime files (URL queue, history, cookies)
data/config/queue.txt
data/config/history.txt
data/config/cookies.txt

# Cookies (sensitive, site-specific)
data/cookies.txt

# Python cache
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# Docker env
.env

# Temp files
*.tmp
*.log
